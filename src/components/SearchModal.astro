---
import Search from "astro-pagefind/components/Search";
---

<div
  id="search-modal"
  class="hidden fixed inset-0 z-50"
  role="dialog"
  aria-modal="true"
  aria-label="Search posts"
>
  <div id="search-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div class="relative flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-lg bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden p-4">
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{
          showImages: false,
          showEmptyFilters: false,
          resetStyles: false,
        }}
      />
    </div>
  </div>
</div>

<style is:global>
  :root {
    --pagefind-ui-primary: #1f2937;
    --pagefind-ui-text: #111827;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-font: inherit;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-weight: 400;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #111827;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: #1f2937;
  }

  .pagefind-ui .pagefind-ui__results-area {
    max-height: 60vh;
    overflow-y: auto;
    margin-top: 0.75rem;
  }

  .pagefind-ui .pagefind-ui__result-link.search-selected {
    background-color: #f3f4f6;
    border-radius: 0.25rem;
  }
</style>

<script>
  import "../scripts/search-modal.ts";
</script>
