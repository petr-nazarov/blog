---
import Search from "astro-pagefind/components/Search";
---

<div
  id="search-modal"
  class="hidden fixed inset-0 z-50"
  role="dialog"
  aria-modal="true"
  aria-label="Search posts"
>
  <div id="search-backdrop" class="absolute inset-0 bg-black/50"></div>
  <div class="relative flex items-start justify-center pt-[15vh] px-4">
    <div class="w-full max-w-lg bg-white rounded-lg shadow-lg border border-gray-200 overflow-hidden p-4">
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{
          showImages: false,
          showEmptyFilters: false,
          resetStyles: false,
        }}
      />
    </div>
  </div>
</div>

<style is:global>
  :root {
    --pagefind-ui-primary: #1f2937;
    --pagefind-ui-text: #111827;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e5e7eb;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.5rem;
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-font: inherit;
  }

  .pagefind-ui .pagefind-ui__search-input {
    font-weight: 400;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: #111827;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    color: #1f2937;
  }

  .pagefind-ui .pagefind-ui__results-area {
    max-height: 60vh;
    overflow-y: auto;
    margin-top: 0.75rem;
  }

  .pagefind-ui .pagefind-ui__result-link.search-selected {
    background-color: #f3f4f6;
    border-radius: 0.25rem;
  }
</style>

<script>
  function initSearch() {
    const modal = document.getElementById("search-modal")!;
    const backdrop = document.getElementById("search-backdrop")!;
    const searchContainer = document.getElementById("search")!;

    let selectedIndex = -1;

    function getResultLinks(): NodeListOf<HTMLAnchorElement> {
      return searchContainer.querySelectorAll<HTMLAnchorElement>(".pagefind-ui__result-link");
    }

    function updateSelection() {
      const links = getResultLinks();
      links.forEach((link, i) => {
        if (i === selectedIndex) {
          link.classList.add("search-selected");
          link.scrollIntoView({ block: "nearest" });
        } else {
          link.classList.remove("search-selected");
        }
      });
    }

    function getQuery(): string {
      const input = modal.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      return input?.value?.trim() ?? "";
    }

    function rewriteLinks() {
      const query = getQuery();
      if (!query) return;
      const links = getResultLinks();
      links.forEach((link) => {
        try {
          const url = new URL(link.href);
          url.searchParams.set("highlight", query);
          link.href = url.toString();
        } catch {
          // skip malformed URLs
        }
      });
    }

    // Observe Pagefind result changes
    const observer = new MutationObserver(() => {
      selectedIndex = -1;
      updateSelection();
      rewriteLinks();
    });
    observer.observe(searchContainer, { childList: true, subtree: true });

    function open() {
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      selectedIndex = -1;
      const input = modal.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      if (input) {
        input.value = "";
        input.focus();
        input.dispatchEvent(new Event("input", { bubbles: true }));
      }
    }

    function close() {
      modal.classList.add("hidden");
      document.body.style.overflow = "";
      selectedIndex = -1;
    }

    function isEditableTarget(target: EventTarget | null): boolean {
      if (target instanceof HTMLElement) {
        return target.isContentEditable || target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement;
      }
      return false;
    }

    // Global keyboard shortcuts
    document.addEventListener("keydown", (e) => {
      if (((e.metaKey || e.ctrlKey) && e.key === "k") || (e.key === "/" && !isEditableTarget(e.target))) {
        e.preventDefault();
        if (modal.classList.contains("hidden")) {
          open();
        } else {
          close();
        }
      }
      if (e.key === "Escape" && !modal.classList.contains("hidden")) {
        e.preventDefault();
        close();
      }
    });

    // Arrow navigation and Enter on the search input
    searchContainer.addEventListener("keydown", (e) => {
      const links = getResultLinks();
      if (links.length === 0) return;

      if (e.key === "ArrowDown") {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, links.length - 1);
        updateSelection();
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, -1);
        updateSelection();
      } else if (e.key === "Enter" && selectedIndex >= 0 && links[selectedIndex]) {
        e.preventDefault();
        window.location.href = links[selectedIndex].href;
      }
    });

    // Reset selection on input change
    searchContainer.addEventListener("input", () => {
      selectedIndex = -1;
    });

    backdrop.addEventListener("click", close);

    document.getElementById("search-trigger")?.addEventListener("click", open);
  }

  initSearch();
  document.addEventListener("astro:after-swap", initSearch);
</script>
