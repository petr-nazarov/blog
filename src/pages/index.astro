---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="Blog">
  <h1 class="text-3xl font-bold mb-8">Posts</h1>
  {posts.length === 0 && <p class="text-gray-500">No posts yet.</p>}
  <ul class="space-y-6">
    {posts.map((post) => (
      <li>
        <a href={`/posts/${post.id}`} class="group block">
          <h2 class="text-xl font-semibold group-hover:underline">{post.data.title}</h2>
          <time class="text-sm text-gray-500" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
          <p class="text-gray-600 mt-1">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</Base>
