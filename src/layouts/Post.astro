---
import type { MarkdownHeading } from "astro";
import Base from "./Base.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AuthorCard from "../components/AuthorCard.astro";
import { SITE, AUTHOR } from "../consts";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  headings: MarkdownHeading[];
  slug: string;
}

const { title, description, date, tags, headings, slug } = Astro.props;

const articleUrl = new URL(`/posts/${slug}`, SITE.url);
const hasToc = headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0;
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  url: articleUrl,
  author: { "@id": `${SITE.url}/#person` },
  publisher: { "@id": `${SITE.url}/#person` },
  isPartOf: { "@id": `${SITE.url}/#website` },
  ...(tags && { keywords: tags.join(", ") }),
});
---

<Base
  title={title}
  description={description}
  ogType="article"
  article={{
    publishedTime: date.toISOString(),
    authors: [AUTHOR.name],
    tags,
  }}
>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />

  <!-- Mobile TOC: collapsible -->
  {hasToc && (
    <details class="toc-mobile xl:hidden mb-8 border border-gray-200 rounded px-4 py-3">
      <summary class="text-sm font-semibold text-gray-700 cursor-pointer select-none">
        Contents
      </summary>
      <div class="mt-3">
        <TableOfContents headings={headings} />
      </div>
    </details>
  )}

  <!-- Desktop TOC: fixed to viewport, positioned next to article -->
  {hasToc && (
    <aside id="toc-sidebar" class="hidden xl:block fixed top-8 w-64" style="left: calc(50% + 25.5rem);">
      <TableOfContents headings={headings} />
    </aside>
  )}

  <article data-pagefind-body>
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{title}</h1>
      <time class="text-sm text-gray-500" datetime={date.toISOString()}>
        {date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      {tags && tags.length > 0 && (
        <div class="mt-2 flex gap-2 flex-wrap">
          {tags.map((tag) => (
            <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-gray max-w-none">
      <slot />
    </div>

    <AuthorCard data-pagefind-ignore />
  </article>

  <script is:inline>
    function scrollToFirstHighlight() {
      requestAnimationFrame(function() {
        var mark = document.querySelector("mark[data-markjs]");
        if (mark) {
          mark.scrollIntoView({ behavior: "smooth", block: "center" });
        }
      });
    }
    (async function initHighlight() {
      try {
        await import("/pagefind/pagefind-highlight.js");
        new window.PagefindHighlight({ highlightParam: "highlight" });
        scrollToFirstHighlight();
      } catch (e) {
        // Highlight script not available (e.g., dev mode)
      }
    })();
    document.addEventListener("astro:after-swap", async function() {
      try {
        await import("/pagefind/pagefind-highlight.js");
        new window.PagefindHighlight({ highlightParam: "highlight" });
        scrollToFirstHighlight();
      } catch (e) {}
    });
  </script>

  <section class="mt-12 pt-8 border-t border-gray-200" aria-label="Comments">
    <h2 class="text-lg font-semibold mb-6">Comments</h2>
    <div class="giscus"></div>
    <script
      is:inline
      src="https://giscus.app/client.js"
      data-repo="petr-nazarov/blog"
      data-repo-id="R_kgDORig9fg"
      data-category="General"
      data-category-id="DIC_kwDORig9fs4C4Btq"
      data-mapping="pathname"
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="preferred_color_scheme"
      data-lang="en"
      crossorigin="anonymous"
      async
    ></script>
  </section>
</Base>
