---
import type { MarkdownHeading } from "astro";
import Base from "./Base.astro";
import TableOfContents from "../components/TableOfContents.astro";
import AuthorCard from "../components/AuthorCard.astro";
import { SITE, AUTHOR } from "../consts";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
  headings: MarkdownHeading[];
  slug: string;
}

const { title, description, date, tags, headings, slug } = Astro.props;

const articleUrl = new URL(`/posts/${slug}`, SITE.url);
const hasToc = headings.filter((h) => h.depth >= 2 && h.depth <= 3).length > 0;
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  url: articleUrl,
  author: {
    "@type": "Person",
    name: AUTHOR.name,
    url: AUTHOR.url,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.title,
  },
  ...(tags && { keywords: tags.join(", ") }),
});
---

<Base
  title={title}
  description={description}
  ogType="article"
  article={{
    publishedTime: date.toISOString(),
    authors: [AUTHOR.name],
    tags,
  }}
>
  <script type="application/ld+json" set:html={jsonLd} slot="head" />

  <!-- Mobile TOC: collapsible -->
  {hasToc && (
    <details class="toc-mobile xl:hidden mb-8 border border-gray-200 rounded px-4 py-3">
      <summary class="text-sm font-semibold text-gray-700 cursor-pointer select-none">
        Contents
      </summary>
      <div class="mt-3">
        <TableOfContents headings={headings} />
      </div>
    </details>
  )}

  <!-- Desktop TOC: fixed to viewport, positioned next to article -->
  {hasToc && (
    <aside id="toc-sidebar" class="hidden xl:block fixed top-8 w-64" style="left: calc(50% + 25.5rem);">
      <TableOfContents headings={headings} />
    </aside>
  )}

  <article>
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">{title}</h1>
      <time class="text-sm text-gray-500" datetime={date.toISOString()}>
        {date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      </time>
      {tags && tags.length > 0 && (
        <div class="mt-2 flex gap-2 flex-wrap">
          {tags.map((tag) => (
            <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose prose-gray max-w-none">
      <slot />
    </div>

    <AuthorCard />
  </article>
</Base>
